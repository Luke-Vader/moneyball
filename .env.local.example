# Supabase project (Settings > API in the dashboard, or `supabase status` for local dev)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never prefix with NEXT_PUBLIC_. Used by the service-role
# client (src/lib/supabase/admin.ts) for the simulate-match route and vault
# credential lookup. Keep this out of version control.
SUPABASE_SERVICE_ROLE_KEY=

# The LLM provider/model/API key for match simulation are NOT set here —
# they're configured at runtime by the admin via /admin/settings and stored
# server-side in Supabase Vault (see supabase/migrations/..._functions.sql).
